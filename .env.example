# Copy to .env and fill in. The UI only needs the PocketBase URL and n8n webhook URLs —
# all scraping secrets (Serper, Apify, verifier keys) live in n8n, never here.

# PocketBase
VITE_PB_URL=http://localhost:8090

# n8n webhook that runs the Phase 1 "Scrape federations" workflow (FIVB VIS ingest).
# The per-row "Rescrape" button POSTs the same URL with a `rescrape` header.
VITE_N8N_SCRAPE_FEDERATIONS_URL=

# n8n webhook the UI's per-row "Discover clubs" button hits — point at the
# "Process federation" orchestrator (discover -> gate -> extract).
VITE_N8N_DISCOVER_CLUBS_URL=

# n8n webhook for the "Process N" batch button (async fan-out over filtered federations).
VITE_N8N_BATCH_PROCESS_URL=
