# Copy to .env and fill in. The UI only needs the PocketBase URL and n8n webhook URLs —
# all scraping secrets (Serper, Apify, verifier keys) live in n8n, never here.

# PocketBase
VITE_PB_URL=http://localhost:8090

# n8n webhook that runs the Phase 1 "Scrape federations" workflow (FIVB VIS ingest).
# The per-row "Rescrape" button POSTs the same URL with a `rescrape` header.
VITE_N8N_SCRAPE_FEDERATIONS_URL=

# n8n webhook the UI's per-row "Discover clubs" button hits — point at the
# "Process federation" orchestrator (discover -> gate -> extract).
VITE_N8N_DISCOVER_CLUBS_URL=

# n8n webhook for the "Process N" batch button (async fan-out over filtered federations).
VITE_N8N_BATCH_PROCESS_URL=

# n8n webhook for the per-row "Extract" button (re-extract from a discovered directory).
VITE_N8N_EXTRACT_CLUBS_URL=

# n8n webhook for the Clubs "Resolve N" button (validate + Serper-resolve websites).
VITE_N8N_BATCH_ENRICH_URL=

# n8n webhook for the Clubs "Englishize names" button (romanize non-Latin club names).
VITE_N8N_ENGLISHIZE_CLUBS_URL=

# n8n webhook for the Clubs "Scrape sites for contacts" button (site-scrape-driver;
# crawls live club sites for contacts). Accepts {ids} to scope to the current filter.
VITE_N8N_SITE_SCRAPE_URL=

# n8n webhook for the scrape queue (Clubs "Scrape" button enqueues; cron drains).
VITE_N8N_SCRAPE_ENQUEUE_URL=

# n8n webhook for the Contacts "Verify emails (Reoon)" button — batch email verification.
VITE_N8N_VERIFY_CONTACTS_URL=

# n8n webhook for the Contacts "Sync deliverable to Brevo" button — pushes verified contacts.
VITE_N8N_SYNC_BREVO_URL=

# n8n webhook for the Contacts "Import from Brevo (backfill)" button — one-time Brevo->DB import.
VITE_N8N_BREVO_BACKFILL_URL=

# Server-side (PocketBase hook, NOT a VITE_ var): n8n webhook the contact-delete hook POSTs to
# so a deleted contact is hard-deleted in Brevo. Defaults to the known n8n instance if unset.
# N8N_BREVO_DELETE_URL=https://n8n-2.biceps.digital/webhook/brevo-contact-delete
