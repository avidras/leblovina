      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -520,
        0
      ],
      "credentials": {
        "httpCustomAuth": {
          "id": "hzdBwrAqrPZjDmME",
          "name": "PocketBase admin (api)"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Default = whole Brevo account (all lists). Pass body.list_id to scope to one list.\nconst body=($('Webhook').first().json.body)||{};\nconst listId=(body.list_id!=null)?Number(body.list_id):null;\nconst path=(listId!=null)?('/v3/contacts/lists/'+listId+'/contacts'):'/v3/contacts';\nreturn [{json:{path, listId}}];\n"
      },
      "id": "resolve",
      "name": "Resolve",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -340,
        0
      ]
    },
    {
      "parameters": {
        "url": "=https://api.brevo.com{{ $json.path }}?limit=1",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "count",
      "name": "Count",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -160,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_BREVO_CRED",
          "name": "Brevo (api)"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Build explicit offset pages from Brevo's total count (deterministic — no auto-pagination).\nconst cnt = ((($('Count').first()||{}).json)||{}).count || 0;\nconst path = ((($('Resolve').first()||{}).json)||{}).path || '/v3/contacts';\nconst pages = Math.ceil(cnt/1000);\nconst out=[];\nfor(let i=0;i<pages;i++){ out.push({json:{path, offset:i*1000}}); }\nreturn out;\n"
      },
      "id": "offsets",
      "name": "Make offsets",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        20,
        0
      ]
    },
    {
      "parameters": {
        "url": "=https://api.brevo.com{{ $json.path }}?limit=1000&offset={{ $json.offset }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 30000
        }
      },
      "id": "page",
      "name": "Brevo page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        200,
        0
      ],
      "onError": "continueRegularOutput",
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_BREVO_CRED",
          "name": "Brevo (api)"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const PB_URL=($('Config').first().json.pbUrl||'').replace(/\\/+$/,'');\nconst token=$('PB Auth').first().json.token; const pbH={Authorization:token};\nconst pages=$input.all();\n// email -> blocklisted (Brevo emailBlacklisted is authoritative)\nconst map=new Map();\nfor(const p of pages){ const cs=(p.json&&p.json.contacts)||[]; for(const c of cs){ if(c&&c.email){ map.set(String(c.email).trim().toLowerCase(), c.emailBlacklisted===true); } } }\nconst entries=[...map.entries()];\nlet created=0, updated=0, skipped=0;\nconst upsert=async([email,bl])=>{\n  try{ await this.helpers.httpRequest({method:'POST',url:PB_URL+'/api/collections/contacts/records',headers:pbH,body:{email,source_type:'brevo',blocklisted:bl},json:true}); created++; }\n  catch(e){\n    // already exists -> refresh its blocklisted flag from Brevo if it changed\n    try{ const r=await this.helpers.httpRequest({method:'GET',url:PB_URL+'/api/collections/contacts/records',qs:{filter:'email=\"'+email+'\"',perPage:1,fields:'id,blocklisted'},headers:pbH,json:true}); const rec=r.items&&r.items[0]; if(rec){ if(rec.blocklisted!==bl){ await this.helpers.httpRequest({method:'PATCH',url:PB_URL+'/api/collections/contacts/records/'+rec.id,headers:pbH,body:{blocklisted:bl},json:true}); updated++; } } else { skipped++; } }catch(_){ skipped++; }\n  }\n};\nfor(let i=0;i<entries.length;i+=40){ await Promise.all(entries.slice(i,i+40).map(upsert)); }\nreturn [{json:{created,updated,total:entries.length}}];\n"
      },
      "id": "upsert",
      "name": "Upsert into PB",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        0
      ]
    }
  ],
